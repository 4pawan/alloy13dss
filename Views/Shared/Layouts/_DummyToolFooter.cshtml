@model IDummySettingsPage

<footer class="dummy-theme__footer">
    <span>Dummy Tools</span>
    @if (Model?.FooterLinks?.Any() == true)
    {
        <nav class="dummy-theme__nav" aria-label="Footer links">
            @foreach (var link in Model.FooterLinks)
            {
                <a href="@link.Href" title="@link.Title" target="@link.Target">@link.Text</a>
            }
        </nav>
    }
    else
    {
        <span class="dummy-theme__nav">Configurable CMS journeys powered by reusable form containers.</span>
    }
</footer>
